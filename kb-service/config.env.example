# LLM Provider Configuration для KB
# Выбор провайдера: 'openai' или 'ollama'
LLM_PROVIDER=openai

# OpenAI/ProxyAPI Configuration (для генерации embeddings и LLM)
OPENAI_API_KEY=sk-0rjJ3guVbISwIjvhypozyF4YEicN2fUY
OPENAI_BASE_URL=https://api.proxyapi.ru/openai/v1
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.2
OPENAI_TIMEOUT=60

# Embedding Model Configuration
# Используется для генерации векторных представлений текста
# Варианты:
# - OpenAI: text-embedding-3-small (1536 dim) или text-embedding-3-large (3072 dim)
# - HuggingFace: intfloat/multilingual-e5-base (768 dim)
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# HuggingFace Model Configuration (альтернатива OpenAI)
HF_MODEL_NAME=intfloat/multilingual-e5-base
HF_EMBEDDING_DIMENSION=768

# Database Configuration (PostgreSQL с pgvector)
# Укажите базу brats (создаётся через db-init/init_all.sh, config.env в корне проекта)
DATABASE_URL=postgresql://postgres:1234@localhost:5432/brats

# KB Table Configuration
KB_TABLE=knowledge_base

# Chunking Configuration для KB
# Размеры чанков для разных типов контента KB
CHUNK_SIZE_PRODUCT_INFO=3000
CHUNK_SIZE_SALES_SCRIPT=2000
CHUNK_SIZE_OBJECTION_HANDLING=1500
CHUNK_SIZE_DOCUMENTATION=3000

# Перекрытия (overlap) для сохранения контекста
CHUNK_OVERLAP_PRODUCT_INFO=300
CHUNK_OVERLAP_SALES_SCRIPT=200
CHUNK_OVERLAP_OBJECTION_HANDLING=150
CHUNK_OVERLAP_DOCUMENTATION=300

# Использовать умное разбиение по границам предложений/абзацев
CHUNK_USE_SMART_BOUNDARIES=true

# Gemini Configuration (через ProxyAPI.ru) для библиотекаря MMKB
GEMINI_API_KEY=your_proxyapi_key_here
GEMINI_BASE_URL=https://api.proxyapi.ru/google
GEMINI_MODEL=gemini-3-pro-preview
GEMINI_TEMPERATURE=0.2
GEMINI_TIMEOUT=120

# API Configuration
API_HOST=0.0.0.0
API_PORT=8001

# ============================================
# n8n Integration Configuration
# ============================================
# URL для доступа к n8n (для интеграции workflows)
N8N_URL=http://localhost:5678
N8N_WEBHOOK_URL=http://localhost:5678/
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme

