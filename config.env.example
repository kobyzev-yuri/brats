# ============================================
# Общая конфигурация проекта BRATS
# ============================================

# ============================================
# n8n Configuration
# ============================================
# URL для доступа к n8n
N8N_URL=http://localhost:5678
N8N_PROTOCOL=http
N8N_HOST=0.0.0.0
N8N_PORT=5678

# Аутентификация n8n
# Для локальной разработки: отключите basic auth (false)
# Для продакшена: включите basic auth (true) и установите пароль
N8N_BASIC_AUTH_ACTIVE=false
# N8N_BASIC_AUTH_USER=admin
# N8N_BASIC_AUTH_PASSWORD=changeme

# Первый пользователь n8n (создается автоматически при первом запуске)
# Если пользователь уже существует, эти переменные игнорируются
N8N_USER_FIRST_NAME=Admin
N8N_USER_LAST_NAME=User
N8N_USER_EMAIL=admin@example.com
N8N_USER_PASSWORD=changeme

# Лицензионный ключ n8n (получите на https://n8n.io/pricing). Для локального n8n без Docker.
N8N_LICENSE_KEY=8d966e15-51be-4b26-9f36-c6c922fa0a5e

# Webhook URL для n8n (для внешних интеграций)
# Полный URL webhook для чата (прокси на 8000 дергает этот адрес). Без слеша в конце.
N8N_WEBHOOK_URL=http://localhost:5678/webhook/sales-agent-kb

# Локальный n8n по HTTP: false — иначе куки не работают, не получится подтвердить лицензию/логин
# N8N_SECURE_COOKIE=false

# Хост для доступа из контейнера n8n к сервисам на хосте (KB :8001, sales-agent :8003).
# Используется в start_n8n.sh и docker-compose.yml. Значение host-gateway — специальный IP хоста в Docker.
N8N_EXTRA_HOSTS=host.docker.internal:host-gateway

# ============================================
# ProxyAPI.ru / LLM для n8n и kb-service (OpenAI-совместимый API)
# ============================================
# Ключ proxyapi.ru (получить на https://proxyapi.ru). При запуске n8n/kb-service
# если OPENAI_API_KEY не задан, подставляется PROXYAPI_KEY.
PROXYAPI_KEY=sk-0rjJ3guVbISwIjvhypozyF4YEicN2fUY

# Эндпоинт и модель (proxyapi.ru OpenAI-совместимый)
OPENAI_BASE_URL=https://api.proxyapi.ru/openai/v1
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.2

# Ключ для n8n workflow и kb-service. Можно задать отдельно или оставить пустым — тогда используется PROXYAPI_KEY.
OPENAI_API_KEY=sk-0rjJ3guVbISwIjvhypozyF4YEicN2fUY

# ============================================
# KB Service Configuration
# ============================================
# URL для доступа к KB Service API
KB_API_URL=http://localhost:8001
# Лимит размера файла при импорте документа (МБ). По умолчанию в коде 100.
# KB_IMPORT_MAX_FILE_MB=100

# ============================================
# Sales Agent Configuration
# ============================================
# URL для доступа к агенту продаж (когда будет реализован)
SALES_AGENT_URL=http://localhost:8000

# ============================================
# Database Configuration
# ============================================
# PostgreSQL connection string (используется для KB и других сервисов)
DATABASE_URL=postgresql://postgres:1234@localhost:5432/brats

# ============================================
# AmoCRM (amocrm-api на :8010, скрипты scripts/check_amocrm_*.py)
# ============================================
# Базовый URL amocrm-api (n8n: память диалога Resolve, создание лидов). Без слеша в конце.
AMOCRM_API_BASE_URL=http://localhost:8010
# URL funnel-api (для ЛК: список КП и превью договора в разделе «Прикреплённые документы»)
# FUNNEL_API_BASE_URL=http://localhost:8011
# Поддомен (например innovatoryclub)
# AMOCRM_SUBDOMAIN=your-subdomain
# Токены из интеграции AmoCRM (OAuth2). См. docs/AMOCRM_API_SETUP.md
# AMOCRM_ACCESS_TOKEN=
# AMOCRM_REFRESH_TOKEN=
# Опционально: тестовая воронка и ID полей контакта/сделки (телефон, email).
# Если не заданы — amocrm-api подставляет поля по данным из AmoCRM (custom_fields по code/name: PHONE, EMAIL, «телефон», «Source phone» и т.д.).
# AMOCRM_TEST_PIPELINE_ID=10140478
# Этап «Успешно реализовано» для закрытия сделки (POST /api/leads/{id}/close). Воронка «Работы маркетинг»: 142.
# AMOCRM_CLOSED_SUCCESS_STATUS_ID=142
# Этапы воронки: сдвиг при формировании КП и договора (PATCH /api/leads/{id}/status). Задайте ID этапов из вашей воронки.
# AMOCRM_STATUS_KP_SENT=          — этап «КП/смета отправлена» (funnel-api вызывает после создания КП)
# AMOCRM_STATUS_CONTRACT_SENT=    — этап «Договор/документы отправлены» (funnel-api вызывает после prepare-email договора)
# AMOCRM_CONTACT_PHONE_FIELD_ID=   — телефон у контактов
# AMOCRM_CONTACT_EMAIL_FIELD_ID=   — email у контактов
# AMOCRM_LEAD_PHONE_FIELD_ID=      — телефон на карточке сделки (Source phone, Раб. тел. и т.п.)
# AMOCRM_LEAD_EMAIL_FIELD_ID=      — email на карточке сделки

# Доп. поля сделки (для справки, синхронизации и промпта ЛК — см. docs/PERSONAL_CABINET_LK.md)
# ID полей из вашего AmoCRM; при опросе в ЛК агент уточняет эти параметры.
# AMOCRM_FIELD_WHEN_PLAN_BUY=1292815
# AMOCRM_FIELD_PAYMENT_METHOD=1292817
# AMOCRM_FIELD_MORTGAGE_PREAPPROVAL=1292819
# AMOCRM_FIELD_APPROVED_AMOUNT=1292827
