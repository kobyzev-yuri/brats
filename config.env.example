# AMOCRM_FIELD_FOUNDATION=1292895
# AMOCRM_FIELD_UTILITIES=1292897
# AMOCRM_FIELD_PROJECT=1292899
# AMOCRM_FIELD_PROJECT_FILE=1292901
# AMOCRM_FIELD_OBJECT_HANDOVER=1292903
# AMOCRM_FIELD_TERRITORY=1292905
# AMOCRM_FIELD_EXTRA_BUILDINGS=1292907
# AMOCRM_FIELD_SAFETY=1292909
# AMOCRM_FIELD_EXTRA_INFO=1292911
# AMOCRM_FIELD_EXTRA_AGREEMENT=1292913
# AMOCRM_FIELD_WORKS_HANDOVER=1292915
# AMOCRM_FIELD_FINISH_TYPE_2=1302019
# AMOCRM_FIELD_AVITO_LINK=1302769
# AMOCRM_FIELD_CHAT_LINK=1302771
# AMOCRM_FIELD_SOURCE_PHONE=1304897
# AMOCRM_FIELD_REFUSAL_REASON=1319361
# AMOCRM_FIELD_IMYA=1363843
# AMOCRM_FIELD_VID_OTDELKI=1363845
# AMOCRM_FIELD_PERVONACHALNII_VZNOS=1363847
# AMOCRM_FIELD_PLOSCHAD_DOMA=1363853
# AMOCRM_FIELD_KAKOI_REMONT=1363855
# AMOCRM_FIELD_KAK_POLUCHIT_TSENU=1363857

# ============================================
# MMKB: аннотирование изображений (vision)
# ============================================
# Вариант 1: использовать VisionAnalyzer из проекта 3dtoday (Gemini + fallback Ollama).
# Путь к backend 3dtoday (корень каталога backend или корень репо 3dtoday).
# VISION_3DTODAY_PATH=/home/user/3dtoday/backend
# USE_3DTODAY_VISION=true

# Вариант 2: встроенный Gemini Vision в kb-service (если 3dtoday не используется).
# USE_GEMINI_FOR_VISION=true
# GEMINI_API_KEY=...
# GEMINI_BASE_URL=https://api.proxyapi.ru/google
# GEMINI_VISION_MODEL=gemini-2.0-flash
# GEMINI_MODEL=gemini-2.0-flash

# Если оба отключены — аннотирование картинок идёт через LLMService (GPT-4o).

# ============================================
# Примечания
# ============================================
# 1. Скопируйте этот файл в config.env и заполните реальными значениями
# 2. Не коммитьте config.env в git (он в .gitignore)
# 3. Для разных окружений (dev/prod) используйте разные config.env файлы
# 4. Переменные AmoCRM нужны для amocrm-api (лиды из чата) и скриптов scripts/check_amocrm_*.py. Если вы уже тестировали — добавьте AMOCRM_SUBDOMAIN и AMOCRM_ACCESS_TOKEN (и при необходимости AMOCRM_REFRESH_TOKEN) в config.env в корне репозитория.

